# 竹瑾居内容后台
# 生产环境请务必配置下面这些变量，否则 /admin 不能登录，线上也无法保存内容。

# 管理员登录邮箱
ADMIN_EMAIL=admin@zhujinju.com

# 管理员登录密码
ADMIN_PASSWORD=replace-with-strong-password

# 后台会话签名密钥，建议使用随机长字符串
ADMIN_SESSION_SECRET=replace-with-random-session-secret

# GitHub 内容写回配置
# 后台保存时，会把更新后的 content/site-content.json 提交回 GitHub 仓库，
# 再由 Vercel 自动触发重新部署。
GITHUB_REPO_OWNER=sfa0023918-design
GITHUB_REPO_NAME=zhujinju
GITHUB_REPO_BRANCH=main

# 建议使用 Fine-grained Personal Access Token，仅授予当前仓库 Contents: Read and Write 权限
GITHUB_CONTENTS_TOKEN=replace-with-github-token

# 自动中译英配置
# 用于后台“根据中文生成英文”功能。
# 支持官方 OpenAI，也支持 OpenAI 兼容接口（例如第三方中转 / 兼容服务）。
OPENAI_API_KEY=replace-with-translation-api-key

# 可选。不填则默认使用 https://api.openai.com/v1
OPENAI_TRANSLATION_BASE_URL=https://api.openai.com/v1

# 可选。官方 OpenAI 推荐保持 responses；若使用第三方 OpenAI 兼容接口，可改为 chat
OPENAI_TRANSLATION_API_STYLE=responses

# 可选。不填则默认使用 gpt-5-mini
OPENAI_TRANSLATION_MODEL=gpt-5-mini

# 联系表单邮件投递（Resend）
# 用于把官网联系表单真正发送到你的收件箱。
RESEND_API_KEY=replace-with-resend-api-key

# 发件人，建议使用已在 Resend 验证过域名的邮箱，例如：
# Zhu Jin Ju <noreply@zhujinju.com>
INQUIRY_FROM_EMAIL=Zhu Jin Ju <noreply@zhujinju.com>

# 收件人，可填写一个或多个邮箱，多个用英文逗号分隔
INQUIRY_TO_EMAIL=contact@zhujinju.com
