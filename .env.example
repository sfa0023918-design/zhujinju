# 竹瑾居内容后台
# 生产环境请务必配置下面这些变量，否则 /admin 不能登录，线上也无法保存内容。

# 管理员登录邮箱
ADMIN_EMAIL=admin@zhujinju.com

# 管理员登录密码
ADMIN_PASSWORD=replace-with-strong-password

# 后台会话签名密钥，建议使用随机长字符串
ADMIN_SESSION_SECRET=replace-with-random-session-secret

# GitHub 内容写回配置
# 后台保存时，会把更新后的 content/site-content.json 提交回 GitHub 仓库，
# 再由 Vercel 自动触发重新部署。
GITHUB_REPO_OWNER=sfa0023918-design
GITHUB_REPO_NAME=zhujinju
GITHUB_REPO_BRANCH=main

# 建议使用 Fine-grained Personal Access Token，仅授予当前仓库 Contents: Read and Write 权限
GITHUB_CONTENTS_TOKEN=replace-with-github-token
